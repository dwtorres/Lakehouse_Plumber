{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "LakehousePlumber Project Configuration",
    "description": "Schema for LakehousePlumber project configuration (lhp.yaml)",
    "type": "object",
    "required": ["name"],
    "properties": {
        "name": {
            "type": "string",
            "description": "Name of the project"
        },
        "version": {
            "type": "string",
            "default": "1.0",
            "description": "Version of the project"
        },
        "description": {
            "type": "string",
            "description": "Description of the project"
        },
        "author": {
            "type": "string",
            "description": "Author of the project"
        },
        "created_date": {
            "type": "string",
            "description": "Creation date of the project"
        },
        "include": {
            "type": "array",
            "description": "List of glob patterns to include when processing pipeline files",
            "items": {
                "type": "string",
                "description": "Glob pattern for files to include (e.g., 'bronze_*.yaml', 'silver/**/*.yaml')"
            },
            "examples": [
                ["bronze_*.yaml", "silver_*.yaml"],
                ["pipelines/*/bronze/*.yaml", "ingestion/**/*.yaml"],
                ["*.yaml"]
            ]
        },
        "required_lhp_version": {
            "type": "string",
            "description": "Required LakehousePlumber version range (e.g., '>=0.4.1,<0.5.0')",
            "examples": [
                ">=0.4.1,<0.5.0",
                "~=0.4.1",
                "==0.4.1"
            ]
        },
        "operational_metadata": {
            "type": "object",
            "description": "Project-level operational metadata configuration",
            "properties": {
                "columns": {
                    "type": "object",
                    "description": "Column definitions for operational metadata",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "expression": {
                                "type": "string",
                                "description": "Spark SQL expression for the column"
                            },
                            "description": {
                                "type": "string",
                                "description": "Description of the column"
                            },
                            "applies_to": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": ["streaming_table", "materialized_view","view"]
                                },
                                "default": ["streaming_table", "materialized_view"],
                                "description": "Which write target types this column applies to"
                            },
                            "additional_imports": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Additional imports needed for this column"
                            },
                            "enabled": {
                                "type": "boolean",
                                "default": true,
                                "description": "Whether this column is enabled"
                            }
                        },
                        "required": ["expression"]
                    }
                },
                "presets": {
                    "type": "object",
                    "description": "Preset definitions for operational metadata",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "columns": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "List of column names in this preset"
                            },
                            "description": {
                                "type": "string",
                                "description": "Description of the preset"
                            }
                        },
                        "required": ["columns"]
                    }
                },
                "defaults": {
                    "type": "object",
                    "description": "Default operational metadata settings",
                    "additionalProperties": true
                }
            }
        },
        "event_log": {
            "type": "object",
            "description": "Project-level event log configuration for pipeline resources",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether project-level event logging is enabled"
                },
                "catalog": {
                    "type": "string",
                    "description": "Catalog for event log tables (supports LHP substitution tokens)"
                },
                "schema": {
                    "type": "string",
                    "description": "Schema for event log tables (supports LHP substitution tokens)"
                },
                "name_prefix": {
                    "type": "string",
                    "default": "",
                    "description": "Prefix prepended to pipeline name for event log table name"
                },
                "name_suffix": {
                    "type": "string",
                    "default": "",
                    "description": "Suffix appended to pipeline name for event log table name"
                }
            }
        },
        "monitoring": {
            "type": "object",
            "description": "Event log monitoring pipeline configuration. Generates a notebook with N independent streaming queries plus a SDP pipeline with materialized views. A Databricks Workflow job chains the two.",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the monitoring pipeline is enabled"
                },
                "pipeline_name": {
                    "type": "string",
                    "description": "Name of the monitoring pipeline (default: ${project_name}_event_log_monitoring)"
                },
                "catalog": {
                    "type": "string",
                    "description": "Catalog for monitoring tables (default: event_log.catalog)"
                },
                "schema": {
                    "type": "string",
                    "description": "Schema for monitoring tables (default: event_log.schema)"
                },
                "streaming_table": {
                    "type": "string",
                    "default": "all_pipelines_event_log",
                    "description": "Name of the user-created Delta table that event log streams write into"
                },
                "checkpoint_path": {
                    "type": "string",
                    "description": "Base path for streaming checkpoints. Each pipeline gets a subdirectory: {checkpoint_path}/{pipeline_name}/"
                },
                "max_concurrent_streams": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 1,
                    "description": "Maximum number of concurrent streaming queries in the union notebook (ThreadPoolExecutor max_workers)"
                },
                "materialized_views": {
                    "type": "array",
                    "description": "List of materialized views to create from the unified event log Delta table",
                    "items": {
                        "type": "object",
                        "required": ["name"],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Name of the materialized view"
                            },
                            "sql": {
                                "type": "string",
                                "description": "Inline SQL for the materialized view"
                            },
                            "sql_path": {
                                "type": "string",
                                "description": "Path to external SQL file for the materialized view"
                            }
                        }
                    }
                },
                "enable_job_monitoring": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable job monitoring via Databricks SDK (adds jobs_stats materialized view)"
                }
            }
        }
    }
} 