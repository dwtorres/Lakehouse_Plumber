# ADR-002 T4.1 resolution — Databricks serverless notebook tasks (runtime
# client.5.1) do not auto-add the workspace.file_path root to sys.path, so
# the vendored lhp_watermark package is not importable by default. Infer
# the bundle files root from the running notebook path and prepend it
# before the lhp_watermark imports below. Guarded so static import of the
# file (e.g. template render tests) does not raise when dbutils is absent.
import json
import os
import sys
from datetime import datetime, timezone


def _lhp_watermark_bootstrap_syspath() -> None:
    try:
        nb_path = (
            dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()
        )
        if "/files/" in nb_path:
            ws_root = nb_path.split("/files/")[0] + "/files"
            if not ws_root.startswith("/Workspace"):
                ws_root = "/Workspace" + ws_root
            if ws_root not in sys.path:
                sys.path.insert(0, ws_root)
    except Exception:  # noqa: BLE001 — bootstrap must never crash the task
        pass


_lhp_watermark_bootstrap_syspath()

from lhp_watermark.runtime import derive_run_id  # noqa: E402  — import follows sys.path bootstrap
from lhp_watermark.sql_safety import (  # noqa: E402
    SQLInputValidator,
    sql_identifier,
    sql_literal,
    sql_timestamp_literal,
)
from lhp_watermark._merge_helpers import (  # noqa: E402
    execute_with_concurrent_commit_retry,
    is_concurrent_commit_exception,
)

# COMMAND ----------

# FR-L-07: DML against the manifest table must run in UTC.
spark.conf.set("spark.sql.session.timeZone", "UTC")

# COMMAND ----------

# Resolve identifiers from codegen-injected context.
# All values flow through SQLInputValidator.identifier before SQL composition.
wm_catalog = SQLInputValidator.identifier({{ wm_catalog|tojson }})
wm_schema = SQLInputValidator.identifier({{ wm_schema|tojson }})
manifest_table = f"{wm_catalog}.{wm_schema}.b2_manifests"

# COMMAND ----------

# R9: Auto-DDL — create b2_manifests on first run. IF NOT EXISTS is the
# idempotency guard; no SHOW TABLES pre-check needed (mirrors
# WatermarkManager._ensure_table_exists pattern for pure DDL path).
_ddl = f"""
    CREATE TABLE IF NOT EXISTS {manifest_table} (
        batch_id         STRING NOT NULL,
        action_name      STRING NOT NULL,
        source_system_id STRING NOT NULL,
        schema_name      STRING NOT NULL,
        table_name       STRING NOT NULL,
        load_group       STRING NOT NULL,
        worker_run_id    STRING,
        execution_status STRING NOT NULL,
        created_at       TIMESTAMP NOT NULL,
        updated_at       TIMESTAMP NOT NULL,
        CONSTRAINT pk_b2_manifests PRIMARY KEY (batch_id, action_name)
    )
    USING DELTA
    CLUSTER BY (batch_id)
    TBLPROPERTIES (
        'delta.enableChangeDataFeed' = 'true',
        'delta.autoOptimize.optimizeWrite' = 'true',
        'delta.autoOptimize.autoCompact' = 'true'
    )
"""
spark.sql(_ddl)

# COMMAND ----------

# R1a: batch_id derived once at task entry. DAB retries produce a fresh
# batch_id (per runtime.py:97); orphaned rows from a prior attempt are
# slow-leaked (no hard delete) and visible for audit.
batch_id = derive_run_id(dbutils)
# Validate the batch_id before any SQL composition.
SQLInputValidator.string(batch_id)

# COMMAND ----------

# R1: Build manifest source rows from codegen-injected actions list.
# Each interpolated value is rendered with tojson at the template level so
# the rendered notebook contains Python string literals; runtime validation
# via sql_literal(...) prevents SQL injection before MERGE composition.
# Mirror the tojson literal-injection pattern from jdbc_watermark_job.py.j2:67-71.
_manifest_rows = [
{% for action in actions %}
    (
        sql_literal(batch_id),
        sql_literal(SQLInputValidator.string({{ action.action_name|tojson }})),
        sql_literal(SQLInputValidator.string({{ action.source_system_id|tojson }})),
        sql_literal(SQLInputValidator.string({{ action.schema_name|tojson }})),
        sql_literal(SQLInputValidator.string({{ action.table_name|tojson }})),
        sql_literal(SQLInputValidator.string({{ action.load_group|tojson }})),
    ),
{% endfor %}
]

_values_fragment = ",\n    ".join(
    f"({batch_id_lit}, {action_name_lit}, {source_system_id_lit}, {schema_name_lit}, {table_name_lit}, {load_group_lit})"
    for (
        batch_id_lit,
        action_name_lit,
        source_system_id_lit,
        schema_name_lit,
        table_name_lit,
        load_group_lit,
    ) in _manifest_rows
)

# COMMAND ----------

# R1 / R1a: MERGE via execute_with_concurrent_commit_retry — inherits the
# same Delta optimistic-concurrency retry semantics as WatermarkManager.
# WHEN MATCHED → only update updated_at (row already exists from a prior run
# sharing the same batch_id, which can happen on an idempotent re-execute).
# WHEN NOT MATCHED → INSERT with execution_status='pending'.
_merge_sql = f"""
MERGE INTO {manifest_table} t
USING (
    SELECT
        s.batch_id,
        s.action_name,
        s.source_system_id,
        s.schema_name,
        s.table_name,
        s.load_group
    FROM VALUES
    {_values_fragment}
    AS s(batch_id, action_name, source_system_id, schema_name, table_name, load_group)
) s
ON t.batch_id = s.batch_id AND t.action_name = s.action_name
WHEN MATCHED THEN UPDATE SET t.updated_at = current_timestamp()
WHEN NOT MATCHED THEN INSERT (
    batch_id, action_name, source_system_id, schema_name, table_name,
    load_group, worker_run_id, execution_status, created_at, updated_at
) VALUES (
    s.batch_id, s.action_name, s.source_system_id, s.schema_name, s.table_name,
    s.load_group, NULL, 'pending', current_timestamp(), current_timestamp()
)
"""


def _on_merge_exhausted(last_exc: BaseException) -> None:
    # LHP-MAN-001: raised when Delta concurrent-commit retry budget is depleted.
    # Placeholder until U4-followup introduces ManifestConcurrencyError class.
    raise RuntimeError(
        f"LHP-MAN-001: b2_manifests MERGE retry budget exhausted after 5 attempts: {last_exc}"
    ) from last_exc


execute_with_concurrent_commit_retry(
    spark,
    _merge_sql,
    on_exhausted=_on_merge_exhausted,
    retry_budget=5,
)

# COMMAND ----------

# R2: Build iterations JSON array — one entry per concrete action.
# Frozen contract: keys MUST match lhp.models.b2_iteration.B2_ITERATION_KEYS.
# Devtest 2026-04-26 (Anomaly A) added jdbc_table, watermark_column, and
# landing_path to this payload so the shared B2 worker can scope each
# iteration to the correct action instead of leaking literals from the
# first action.
_iterations = [
{% for action in actions %}
    {
        "source_system_id": {{ action.source_system_id|tojson }},
        "schema_name": {{ action.schema_name|tojson }},
        "table_name": {{ action.table_name|tojson }},
        "action_name": {{ action.action_name|tojson }},
        "load_group": {{ action.load_group|tojson }},
        "batch_id": batch_id,
        "manifest_table": manifest_table,
        "jdbc_table": {{ action.jdbc_table|tojson }},
        "watermark_column": {{ action.watermark_column|tojson }},
        "landing_path": {{ action.landing_path|tojson }},
    },
{% endfor %}
]

# COMMAND ----------

# R2: Emit taskValue — key MUST be exactly "iterations" (R2 explicit naming).
dbutils.jobs.taskValues.set(key="iterations", value=json.dumps(_iterations))

# COMMAND ----------

# Step 11 (R10): retention — soft-delete manifest rows older than 30 days.
# Runs at the start of every batch; idempotent and cheap (Delta soft-delete +
# later VACUUM clears tombstones). DELETE is bounded: even at fleet scale
# (300 actions × hourly batches × 30 days = 216k rows) the predicate is
# selective on created_at + uses CLUSTER BY (batch_id) liquid clustering.
# Sub-second precision on created_at avoids same-second boundary issues
# (R12 supplemental).
import logging as _retention_logger
_retention_logger.getLogger(__name__).info(
    "manifest_retention: starting 30-day DELETE on %s", manifest_table
)
retention_sql = (
    f"DELETE FROM {manifest_table} "
    f"WHERE created_at < current_timestamp() - INTERVAL 30 DAYS"
)
retention_result = spark.sql(retention_sql)
# spark.sql DELETE returns a DataFrame with num_affected_rows; older
# Spark/mocks may not surface it.
try:
    _row = retention_result.first()
    _deleted = int(_row["num_affected_rows"]) if _row is not None else 0
except (KeyError, IndexError, TypeError, AttributeError):
    _deleted = 0
print(f"manifest_retention: deleted {_deleted} rows older than 30 days")

# COMMAND ----------

# Log payload size for operator visibility into the 48 KB DAB taskValue ceiling.
print(f"manifest entries: {len(_iterations)}, taskvalue payload bytes: {len(json.dumps(_iterations))}")
