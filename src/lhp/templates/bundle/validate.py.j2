# ADR-002 T4.1 resolution — Databricks serverless notebook tasks (runtime
# client.5.1) do not auto-add the workspace.file_path root to sys.path, so
# the vendored lhp_watermark package is not importable by default. Infer
# the bundle files root from the running notebook path and prepend it
# before the lhp_watermark imports below. Guarded so static import of the
# file (e.g. template render tests) does not raise when dbutils is absent.
import json
import os
import sys


def _lhp_watermark_bootstrap_syspath() -> None:
    try:
        nb_path = (
            dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()
        )
        if "/files/" in nb_path:
            ws_root = nb_path.split("/files/")[0] + "/files"
            if not ws_root.startswith("/Workspace"):
                ws_root = "/Workspace" + ws_root
            if ws_root not in sys.path:
                sys.path.insert(0, ws_root)
    except Exception:  # noqa: BLE001 — bootstrap must never crash the task
        pass


_lhp_watermark_bootstrap_syspath()

from lhp_watermark.sql_safety import (  # noqa: E402  — import follows sys.path bootstrap
    SQLInputValidator,
    sql_identifier,
    sql_literal,
)

# COMMAND ----------

# FR-L-07: DML against the manifest table must run in UTC.
spark.conf.set("spark.sql.session.timeZone", "UTC")

# COMMAND ----------

# Resolve identifiers from codegen-injected context.
# All values flow through sql_identifier before SQL composition.
_manifest_table = sql_identifier({{ manifest_table|tojson }})
_watermarks_table = sql_identifier({{ watermarks_table|tojson }})
# load_group is used as a string filter value — use sql_literal, not sql_identifier.
_load_group = sql_literal(SQLInputValidator.string({{ load_group|tojson }}))

# COMMAND ----------

# Resolve batch_id from the upstream prepare_manifest task via DAB taskValues.
# derive_run_id(dbutils) cannot be reused here — validate runs as a separate
# DAB task with a different task_run_id, so it would produce a different token.
# An ORDER BY / LIMIT 1 query is non-deterministic across concurrent batches
# for the same load_group. taskValues is the only correct approach.
_batch_id_raw = dbutils.jobs.taskValues.get(
    taskKey="prepare_manifest",
    key="batch_id",
    default=None,
    debugValue=None,
)

if _batch_id_raw is None:
    raise RuntimeError(
        'LHP-VAL-048: batch_id taskValue absent — validate must run downstream '
        'of prepare_manifest in the same DAB job run. '
        'load_group={{ load_group|tojson }}'
    )

batch_id = SQLInputValidator.string(_batch_id_raw)

# COMMAND ----------

# R5: Validate query — LEFT JOIN manifest rows for this batch onto watermarks
# via worker_run_id. final_status uses a CASE that requires manifest-side
# 'completed' (with worker either also 'completed' or NULL) before treating
# the action as completed. Issue #18 R4: a stale watermarks row matched on
# worker_run_id (e.g., from a prior replay using the same run_id) cannot
# coalesce over a manifest row still in 'running' state — that produced a
# silent false pass under the previous coalesce(worker_status,
# manifest_status) form. The CASE preserves the existing fallback for
# every other case so worker-side intermediate statuses (running,
# landed_not_committed, abandoned) still surface correctly.
#
# Issue #20 — DO NOT reintroduce a time-window predicate here (e.g.,
# `created_at > current_timestamp() - INTERVAL N HOURS`). The original
# scale-out used a 24h window which produced silent `noop_pass` for
# fleets that ran longer than 24 hours (concurrency=1 × ~300 actions).
# PR #25 (issue #19 / U7 in that plan) replaced the window with the
# `WHERE batch_id = …` filter below — `batch_id` flows from
# `prepare_manifest` via DAB taskValue, so the lookup is exact and
# unbounded. Long-running fleets are no longer at risk of false-pass.
_validate_sql = f"""
WITH manifest AS (
    SELECT
        batch_id,
        action_name,
        worker_run_id,
        execution_status  AS manifest_status
    FROM {_manifest_table}
    WHERE batch_id = {sql_literal(batch_id)}
),
worker_states AS (
    SELECT
        m.action_name,
        w.status          AS worker_status
    FROM manifest m
    LEFT JOIN {_watermarks_table} w
        ON w.run_id = m.worker_run_id
),
final AS (
    SELECT
        m.action_name,
        CASE
            WHEN m.manifest_status = 'completed'
                 AND (w.worker_status IS NULL OR w.worker_status = 'completed')
                THEN 'completed'
            WHEN m.manifest_status = 'failed' THEN 'failed'
            -- Issue #18 R4 silent-divergence guard: when manifest is non-
            -- terminal ('running') but a stale watermarks row matched on
            -- worker_run_id shows 'completed', trust manifest. The ELSE
            -- coalesce below would return 'completed' from the stale
            -- watermark and false-pass an action that never actually ran
            -- extraction this batch (DuplicateRunError abort, partial
            -- replay, run_id collision via override widget).
            WHEN m.manifest_status = 'running'
                 AND w.worker_status = 'completed'
                THEN m.manifest_status
            ELSE coalesce(w.worker_status, m.manifest_status)
        END AS final_status
    FROM manifest m
    LEFT JOIN worker_states w USING (action_name)
)
SELECT
    count(*)                                                                       AS expected,
    count_if(final_status = 'completed')                                           AS completed_n,
    count_if(final_status = 'failed')                                              AS failed_n,
    count_if(final_status NOT IN ('completed', 'failed') OR final_status IS NULL)  AS unfinished_n
FROM final
"""

_row = spark.sql(_validate_sql).collect()[0]
expected     = int(_row["expected"])
completed_n  = int(_row["completed_n"])
failed_n     = int(_row["failed_n"])
unfinished_n = int(_row["unfinished_n"])

_summary = {
    "batch_id": batch_id,
    "expected": expected,
    "completed_n": completed_n,
    "failed_n": failed_n,
    "unfinished_n": unfinished_n,
}

# COMMAND ----------

# Empty-batch noop pass (expected == 0 means no actions were seeded).
if expected == 0:
    _summary["status"] = "noop_pass"
    print(f"validate: empty batch — {json.dumps(_summary)}")
    dbutils.notebook.exit(json.dumps(_summary))

# Failure path: enumerate every unfinished/failed action_name for operator
# visibility. Uses the same final_status CASE form as the count query so
# that worker-side intermediate statuses (running, landed_not_committed,
# abandoned) are surfaced correctly — those statuses are never written to
# b2_manifests, so a manifest-only filter would miss them — while still
# applying the issue #18 R4 silent-divergence guard.
# Check failures BEFORE the pass exit so the operator gets a clear error.
if not (completed_n == expected and failed_n == 0 and unfinished_n == 0):
    _unfinished_actions = spark.sql(
        f"""
        WITH manifest AS (
            SELECT
                batch_id,
                action_name,
                worker_run_id,
                execution_status  AS manifest_status
            FROM {_manifest_table}
            WHERE batch_id = {sql_literal(batch_id)}
        ),
        worker_states AS (
            SELECT
                m.action_name,
                w.status          AS worker_status
            FROM manifest m
            LEFT JOIN {_watermarks_table} w
                ON w.run_id = m.worker_run_id
        ),
        final AS (
            SELECT
                m.action_name,
                CASE
                    WHEN m.manifest_status = 'completed'
                         AND (w.worker_status IS NULL OR w.worker_status = 'completed')
                        THEN 'completed'
                    WHEN m.manifest_status = 'failed' THEN 'failed'
                    -- Issue #18 R4 silent-divergence guard (mirrors count
                    -- query above): trust manifest when 'running' and a
                    -- stale watermarks row shows 'completed'.
                    WHEN m.manifest_status = 'running'
                         AND w.worker_status = 'completed'
                        THEN m.manifest_status
                    ELSE coalesce(w.worker_status, m.manifest_status)
                END AS final_status
            FROM manifest m
            LEFT JOIN worker_states w USING (action_name)
        )
        SELECT action_name, final_status
        FROM final
        WHERE final_status != 'completed'
        ORDER BY action_name
        """
    ).collect()
    _summary["status"] = "fail"
    _summary["unfinished_actions"] = [
        {"action": r["action_name"], "status": r["final_status"]}
        for r in _unfinished_actions
    ]
    print(f"validate: FAIL — {json.dumps(_summary)}")
    raise RuntimeError(f"LHP-VAL-050: B2 validate failed — {json.dumps(_summary)}")

# COMMAND ----------
{% if parity_check_enabled %}

# LHP-VAL-049: parity check is not yet implemented.
# The landed-parquet row-count source (landing-row-count table or Delta path
# read) has not shipped. Enabling parity_check_enabled before that source is
# wired would silently pass every batch — raise instead so misconfiguration
# is immediately visible.
raise NotImplementedError(
    "LHP-VAL-049: parity_check_enabled=True but the landed-parquet row-count "
    "source has not shipped yet. Disable parity_check_enabled until the "
    "U6-followup that wires the landing-row-count table or Delta path read."
)

{% endif %}
# Full-pass gate: all actions completed, zero failures, zero unfinished,
# and (if enabled) parity check passed. Exit here so any future commands
# appended after this block do not execute on success.
_summary["status"] = "pass"
print(f"validate: pass — {json.dumps(_summary)}")
dbutils.notebook.exit(json.dumps(_summary))
