# ADR-002 T4.1 resolution — Databricks serverless notebook tasks (runtime
# client.5.1) do not auto-add the workspace.file_path root to sys.path, so
# the vendored lhp_watermark package is not importable by default. Infer
# the bundle files root from the running notebook path and prepend it
# before the lhp_watermark imports below. Guarded so static import of the
# file (e.g. template render tests) does not raise when dbutils is absent.
import json
import os
import sys


def _lhp_watermark_bootstrap_syspath() -> None:
    try:
        nb_path = (
            dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()
        )
        if "/files/" in nb_path:
            ws_root = nb_path.split("/files/")[0] + "/files"
            if not ws_root.startswith("/Workspace"):
                ws_root = "/Workspace" + ws_root
            if ws_root not in sys.path:
                sys.path.insert(0, ws_root)
    except Exception:  # noqa: BLE001 — bootstrap must never crash the task
        pass


_lhp_watermark_bootstrap_syspath()

from lhp_watermark.sql_safety import (  # noqa: E402  — import follows sys.path bootstrap
    SQLInputValidator,
    sql_identifier,
    sql_literal,
)

# COMMAND ----------

# FR-L-07: DML against the manifest table must run in UTC.
spark.conf.set("spark.sql.session.timeZone", "UTC")

# COMMAND ----------

# Resolve identifiers from codegen-injected context.
# All values flow through sql_identifier before SQL composition.
_manifest_table = sql_identifier({{ manifest_table|tojson }})
_watermarks_table = sql_identifier({{ watermarks_table|tojson }})
# load_group is used as a string filter value — use sql_literal, not sql_identifier.
_load_group = sql_literal(SQLInputValidator.string({{ load_group|tojson }}))

# COMMAND ----------

# Resolve batch_id: read MAX(batch_id) from b2_manifests filtered by load_group
# within the last 24 hours. This is the only safe way to reconstruct prepare_
# manifest's batch_id from a separate DAB task — derive_run_id(dbutils) would
# return a different token because validate has a different task_run_id.
# A NULL result means no rows were seeded for this load_group today → noop pass.
_batch_id_row = spark.sql(
    f"""
    SELECT MAX(batch_id) AS batch_id
    FROM   {_manifest_table}
    WHERE  load_group = {_load_group}
      AND  created_at > current_timestamp() - INTERVAL 24 HOURS
    """
).collect()[0]

_batch_id_raw = _batch_id_row["batch_id"]

if _batch_id_raw is None:
    # No manifest rows for this load_group within the 24-hour window.
    # Treat as empty-batch noop pass — nothing was seeded, nothing to validate.
    _summary = {
        "batch_id": None,
        "expected": 0,
        "completed_n": 0,
        "failed_n": 0,
        "unfinished_n": 0,
        "status": "noop_pass",
    }
    print(f"validate: empty batch (no manifest rows in window) — {json.dumps(_summary)}")
    dbutils.notebook.exit(json.dumps(_summary))

batch_id = SQLInputValidator.string(_batch_id_raw)

# COMMAND ----------

# R5: Validate query — LEFT JOIN manifest rows for this batch onto watermarks
# via worker_run_id. coalesce(worker_status, manifest_status) gives the
# effective final_status: if the worker updated watermarks, use that truth;
# otherwise fall back to manifest execution_status (handles cases where the
# worker started but watermark commit was skipped or the worker never ran).
_validate_sql = f"""
WITH manifest AS (
    SELECT
        batch_id,
        action_name,
        worker_run_id,
        execution_status  AS manifest_status
    FROM {_manifest_table}
    WHERE batch_id = {sql_literal(batch_id)}
),
worker_states AS (
    SELECT
        m.action_name,
        w.status          AS worker_status
    FROM manifest m
    LEFT JOIN {_watermarks_table} w
        ON w.run_id = m.worker_run_id
),
final AS (
    SELECT
        m.action_name,
        coalesce(w.worker_status, m.manifest_status) AS final_status
    FROM manifest m
    LEFT JOIN worker_states w USING (action_name)
)
SELECT
    count(*)                                                                       AS expected,
    count_if(final_status = 'completed')                                           AS completed_n,
    count_if(final_status = 'failed')                                              AS failed_n,
    count_if(final_status IN ('pending', 'running', 'landed_not_committed', 'abandoned')) AS unfinished_n
FROM final
"""

_row = spark.sql(_validate_sql).collect()[0]
expected     = int(_row["expected"])
completed_n  = int(_row["completed_n"])
failed_n     = int(_row["failed_n"])
unfinished_n = int(_row["unfinished_n"])

_summary = {
    "batch_id": batch_id,
    "expected": expected,
    "completed_n": completed_n,
    "failed_n": failed_n,
    "unfinished_n": unfinished_n,
}

# COMMAND ----------

# Empty-batch noop pass (expected == 0 means no actions were seeded).
if expected == 0:
    _summary["status"] = "noop_pass"
    print(f"validate: empty batch — {json.dumps(_summary)}")
    dbutils.notebook.exit(json.dumps(_summary))

# Failure path: enumerate failed action_names for operator visibility.
# Check failures BEFORE the pass exit so the operator gets a clear error.
if not (completed_n == expected and failed_n == 0 and unfinished_n == 0):
    _failed_actions = spark.sql(
        f"""
        SELECT action_name
        FROM {_manifest_table}
        WHERE batch_id = {sql_literal(batch_id)}
          AND execution_status = 'failed'
        """
    ).collect()
    _summary["status"] = "fail"
    _summary["failed_actions"] = [r["action_name"] for r in _failed_actions]
    print(f"validate: FAIL — {json.dumps(_summary)}")
    raise RuntimeError(f"LHP-VAL-04A: B2 validate failed — {json.dumps(_summary)}")

# COMMAND ----------
{% if parity_check_enabled %}

# Optional parity check — compares JDBC-rows-read (from watermarks.row_count)
# against landed-parquet rows. Runs BEFORE the final pass exit so a parity
# failure surfaces as LHP-VAL-04B rather than silently passing.
#
# STUB: today both columns reference w.row_count so equality always holds.
# The real landed-parquet row-count source is deferred to a U6-followup that
# wires a landing-row-count table or Delta path read. Replace the second
# `w.row_count` alias with the actual landed-parquet count source when available.
_parity_rows = spark.sql(
    f"""
    SELECT
        m.action_name,
        w.row_count   AS jdbc_rows_read,
        w.row_count   AS landed_rows
    FROM {_manifest_table} m
    JOIN {_watermarks_table} w
        ON w.run_id = m.worker_run_id
    WHERE m.batch_id = {sql_literal(batch_id)}
    """
).collect()

_parity_mismatches = [
    {
        "action": r["action_name"],
        "jdbc": r["jdbc_rows_read"],
        "landed": r["landed_rows"],
    }
    for r in _parity_rows
    if r["jdbc_rows_read"] != r["landed_rows"]
]

if _parity_mismatches:
    _summary["parity_mismatches"] = _parity_mismatches
    raise RuntimeError(f"LHP-VAL-04B: parity check failed — {json.dumps(_summary)}")

{% endif %}
# Full-pass gate: all actions completed, zero failures, zero unfinished,
# and (if enabled) parity check passed. Exit here so any future commands
# appended after this block do not execute on success.
_summary["status"] = "pass"
print(f"validate: pass — {json.dumps(_summary)}")
dbutils.notebook.exit(json.dumps(_summary))
