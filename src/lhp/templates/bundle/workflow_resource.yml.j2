{# task_key (extract_*) is decoupled from notebook filename (__lhp_extract_*)
   to keep DAB UI clean while preventing DLT glob collision.

   ADR-002 (2026-04-19): `environments` / `environment_key` (wheel attachment)
   removed. Runtime library `lhp_watermark` ships via DAB workspace-file sync
   at `${workspace.file_path}/src/lhp_watermark/`; generated notebooks import
   it via PYTHONPATH. `source: WORKSPACE` on each notebook_task is required
   because extraction notebooks live at workspace paths, not bundle paths.

   B2 (execution_mode: for_each): three-task DAB topology.
   prepare_manifest → for_each_ingest (DAB for_each_task) → validate.
   {% raw %} below preserves the literal {{ tasks.prepare_manifest.values.iterations }}
   reference that DAB resolves at runtime. #}
{% if execution_mode == "for_each" %}
resources:
  jobs:
    {{ pipeline_name }}_workflow:
      name: {{ pipeline_name }}_workflow
      tasks:
        - task_key: prepare_manifest
          max_retries: 0
          notebook_task:
            notebook_path: {{ prepare_manifest_path }}
            source: WORKSPACE
        - task_key: for_each_ingest
          depends_on:
            - task_key: prepare_manifest
          for_each_task:
            inputs: "{% raw %}{{tasks.prepare_manifest.values.iterations}}{% endraw %}"
            concurrency: {{ concurrency }}
            task:
              task_key: ingest_one
              notebook_task:
                notebook_path: {{ worker_path }}
                source: WORKSPACE
                base_parameters:
                  __lhp_iteration: "{% raw %}{{input}}{% endraw %}"
              max_retries: {{ max_retries }}
        - task_key: validate
          depends_on:
            - task_key: for_each_ingest
          notebook_task:
            notebook_path: {{ validate_path }}
            source: WORKSPACE
{% else %}
resources:
  jobs:
    {{ pipeline_name }}_workflow:
      name: {{ pipeline_name }}_workflow
      tasks:
{% for task in extraction_tasks %}
        - task_key: {{ task.task_name }}
          notebook_task:
            notebook_path: {{ task.notebook_path }}
            source: WORKSPACE
{% if task.depends_on %}
          depends_on:
{% for task_name in task.depends_on %}
            - task_key: {{ task_name }}
{% endfor %}
{% endif %}
{% endfor %}
        - task_key: {{ dlt_task_name }}
          pipeline_task:
            pipeline_id: {{ dlt_pipeline_ref }}
          depends_on:
{% for task_name in dlt_depends_on %}
            - task_key: {{ task_name }}
{% endfor %}
{% endif %}
