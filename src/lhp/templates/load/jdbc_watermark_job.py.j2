# Databricks notebook source
# Extraction Job: {{ action_name }}
# Generated by Lakehouse Plumber — jdbc_watermark_v2
#
# Control flow matches the L2 §5.3 contract verbatim:
#   1. UTC session timezone (FR-L-07)
#   2. derive_run_id (FR-L-09) — job/task/attempt context, widget override, or local fallback
#   3. insert_new OUTSIDE the try block (FR-L-05) — a DuplicateRunError here means
#      no row was created, so mark_failed would have nothing to transition
#   4. try: JDBC read → aggregate → Parquet write (FR-L-02)
#   5. except: mark_failed(type(e).__name__, str(e)[:4096]) then raise
#   6. mark_complete OUTSIDE and AFTER the try/except (FR-L-01 / FR-L-06a)
import json
import os
import sys
from datetime import datetime, timezone
from decimal import Decimal

from pyspark.sql import functions as F

# ADR-002 T4.1 resolution — Databricks serverless notebook tasks (runtime
# client.5.1) do not auto-add the workspace.file_path root to sys.path, so
# the vendored lhp_watermark package is not importable by default. Infer
# the bundle files root from the running notebook path and prepend it
# before the lhp_watermark imports below. Guarded so static import of the
# file (e.g. template render tests) does not raise when dbutils is absent.
def _lhp_watermark_bootstrap_syspath() -> None:
    try:
        nb_path = (
            dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()
        )
        if "/files/" in nb_path:
            ws_root = nb_path.split("/files/")[0] + "/files"
            if not ws_root.startswith("/Workspace"):
                ws_root = "/Workspace" + ws_root
            if ws_root not in sys.path:
                sys.path.insert(0, ws_root)
    except Exception:  # noqa: BLE001 — bootstrap must never crash the task
        pass


_lhp_watermark_bootstrap_syspath()

from lhp_watermark import (  # noqa: E402  — import follows sys.path bootstrap
    TerminalStateGuardError,
    WatermarkManager,
)
from lhp_watermark.runtime import derive_run_id  # noqa: E402
from lhp_watermark.sql_safety import SQLInputValidator, sql_literal  # noqa: E402

# FR-L-07: DML against the watermark table must run in UTC.
spark.conf.set("spark.sql.session.timeZone", "UTC")

# FR-L-09: run_id provenance (Jobs context → widget override → local-<uuid> fallback).
run_id = derive_run_id(dbutils)

wm = WatermarkManager(
    spark,
    catalog={{ wm_catalog|tojson }},
    schema={{ wm_schema|tojson }},
)

# FR-L-03: every value that participates in SQL passes through SQLInputValidator.
# tojson emits a Python-safe literal so values containing quotes (e.g.
# '"Production"."Product"' for a Postgres pre-quoted identifier) round-trip
# unchanged into the notebook source.
{% if execution_mode == "for_each" %}
# B2 for_each path — unpack iteration kwargs from taskValues / widgets.
# Keys mirror lhp.models.b2_iteration.B2_ITERATION_KEYS — adding a key here
# requires the matching emission in prepare_manifest.py.j2 (and a constant
# update). tests/test_b2_iteration_contract.py enforces the symmetry.
iteration_json = dbutils.widgets.get("__lhp_iteration")
iteration = json.loads(iteration_json)
source_system_id = SQLInputValidator.string(iteration["source_system_id"])
schema_name = SQLInputValidator.string(iteration["schema_name"])
table_name = SQLInputValidator.string(iteration["table_name"])
load_group = SQLInputValidator.string(iteration["load_group"])
batch_id = SQLInputValidator.string(iteration["batch_id"])
manifest_table = SQLInputValidator.identifier(iteration["manifest_table"])
action_name = SQLInputValidator.string(iteration["action_name"])
# Anomaly A (devtest 2026-04-26): the worker is shared across every action in
# the flowgroup, so jdbc_table / watermark_column / landing_path MUST come
# from the iteration payload, never from a codegen-time literal of the first
# action. SecretCodeGenerator regex is sensitive to stray apostrophes in
# comments — keep this block apostrophe-free.
jdbc_table = SQLInputValidator.string(iteration["jdbc_table"])
watermark_column = SQLInputValidator.string(iteration["watermark_column"])
landing_root = iteration["landing_path"]
{% else %}
# legacy static path — keep existing literals
source_system_id = SQLInputValidator.string({{ source_system_id|tojson }})
schema_name = SQLInputValidator.string({{ schema_name|tojson }})
table_name = SQLInputValidator.string({{ table_name|tojson }})
load_group = {{ load_group|tojson }}
watermark_column = SQLInputValidator.string({{ watermark_column|tojson }})
jdbc_table = SQLInputValidator.string({{ jdbc_table|tojson }})
landing_root = {{ landing_path|tojson }}
{% endif %}

hwm_result = wm.get_latest_watermark(
    source_system_id=source_system_id,
    schema_name=schema_name,
    table_name=table_name,
    load_group=load_group,
)
hwm_value = hwm_result["watermark_value"] if hwm_result else None
{% if execution_mode == "for_each" %}
logged_action_name = action_name
{% else %}
logged_action_name = {{ action_name|tojson }}
{% endif %}


def _log_phase(phase: str, **payload):
    event = {"phase": phase, "action": logged_action_name, "run_id": run_id}
    event.update(payload)
    print(json.dumps(event, default=str, sort_keys=True))


def _run_landing_path(root: str, current_run_id: str) -> str:
    return f"{root.rstrip('/')}/_lhp_runs/{current_run_id}"


recoverable = wm.get_recoverable_landed_run(
    source_system_id=source_system_id,
    schema_name=schema_name,
    table_name=table_name,
    load_group=load_group,
)
if recoverable:
    recovered_value = recoverable["watermark_value"] or ""
    recovered_count = int(recoverable["row_count"] or 0)
    _log_phase(
        "recovery_finalize_start",
        recoverable_run_id=recoverable["run_id"],
        recoverable_landing_path=_run_landing_path(landing_root, recoverable["run_id"]),
        row_count=recovered_count,
        watermark_value=recovered_value,
    )
    wm.mark_complete(
        run_id=recoverable["run_id"],
        watermark_value=recovered_value,
        row_count=recovered_count,
        load_group=load_group,
    )
    _log_phase(
        "recovery_finalize_complete",
        recoverable_run_id=recoverable["run_id"],
        row_count=recovered_count,
        watermark_value=recovered_value,
    )
    dbutils.notebook.exit(
        f"Recovered landed batch {recoverable['run_id']} without reopening JDBC"
    )


def _ansi_quote_identifier(value: str) -> str:
    """Quote a JDBC identifier with ANSI double-quotes (portable remote-DB form).

    Spark's ``sql_identifier`` emitter uses backticks, which is wrong for
    Postgres/Oracle/SQL Server JDBC passthrough. This helper is intentionally
    local to the notebook and applies only after SQLInputValidator.string has
    rejected control characters and over-length input.
    """
    return '"' + value.replace('"', '""') + '"'


def _build_jdbc_query(hwm):
    """Compose the JDBC subquery string from validated Python values."""
    # Subquery alias without `AS` — ANSI-compatible, works on Postgres + Oracle.
    # Oracle rejects `AS` in FROM-clause alias position (ORA-03048).
    base = f"(SELECT * FROM {jdbc_table}) t"
    if hwm is None:
        return base
    {% if watermark_type == "timestamp" %}
    # Timestamp watermark: render as an ISO-8601 literal quoted for the remote DB.
    if isinstance(hwm, datetime):
        hwm_dt = hwm
    else:
        hwm_dt = datetime.fromisoformat(str(hwm))
    if hwm_dt.tzinfo is None:
        hwm_dt = hwm_dt.replace(tzinfo=timezone.utc)
    hwm_utc_iso = hwm_dt.astimezone(timezone.utc).isoformat(timespec="microseconds")
    hwm_literal = "'" + hwm_utc_iso.replace("'", "''") + "'"
    {% elif watermark_type == "numeric" %}
    # Numeric watermark: validator rejects float / NaN / Infinity before emission.
    if isinstance(hwm, Decimal):
        hwm_num = hwm
    else:
        try:
            hwm_num = int(str(hwm))
        except ValueError:
            hwm_num = Decimal(str(hwm))
    SQLInputValidator.numeric(hwm_num)
    hwm_literal = str(hwm_num)
    {% endif %}
    # R12 (B2): default operator is ">" for execution_mode: for_each.
    # CAVEATS — operator awareness:
    # 1. Sub-second precision: source watermark column should carry ms/μs precision.
    #    Second-only sources risk losing rows on every re-run if writes share
    #    the same second as max_wm.
    # 2. Late-arriving records at exact max_wm timestamp: strict ">" skips them.
    #    Operator may opt into a Δ-buffer subtraction in source query (e.g.
    #    WHERE wm > max_wm - INTERVAL 5 MINUTE) for slow-emit sources.
    # 3. Same-second collisions on high-volume second-precision sources:
    #    composite tiebreaker (wm_col, pk) > (last_wm, last_pk) is a follow-up
    #    if operator reports row loss.
    # 4. UTC normalization: WatermarkManager._ensure_utc_session() enforces
    #    spark.sql.session.timeZone='UTC' before any DML. The B2 worker path
    #    inherits this via the same prelude.
    op = {{ watermark_operator|tojson }}
    if op not in (">=", ">", "<=", "<", "="):
        raise ValueError(f"unsupported watermark operator: {op!r}")
    col_quoted = _ansi_quote_identifier(watermark_column)
    return f"(SELECT * FROM {jdbc_table} /*lhp-where*/ {col_quoted} {op} {hwm_literal}) t".replace(
        "/*lhp-where*/", "WHERE"
    )


query = _build_jdbc_query(hwm_value)

# FR-L-05 / L2 §5.3: insert_new is OUTSIDE the try block. A DuplicateRunError
# here means no watermark row was created for this invocation, so mark_failed
# has nothing to transition and must not be called.
{% if execution_mode == "for_each" %}
# B2 manifest UPDATE: claim this attempt's worker_run_id (optimistic-concurrency).
# DAB-retry-timeout race: if UPDATE matches zero, read back current state.
worker_run_id = run_id
update_sql = f"""
UPDATE {manifest_table}
SET    worker_run_id    = {sql_literal(worker_run_id)},
       execution_status = 'running',
       updated_at       = current_timestamp()
WHERE  batch_id    = {sql_literal(batch_id)}
  AND  action_name = {sql_literal(action_name)}
  AND  ( worker_run_id IS NULL OR worker_run_id = {sql_literal(worker_run_id)} )
"""
update_result = spark.sql(update_sql)
# If zero rows affected, another retry-attempt may already own this row.
# Read back; if we're not the current owner, abort with a retry-friendly error.
readback = spark.sql(
    f"SELECT worker_run_id FROM {manifest_table} "
    f"WHERE batch_id = {sql_literal(batch_id)} "
    f"AND action_name = {sql_literal(action_name)}"
).collect()
if readback and readback[0]["worker_run_id"] not in (None, worker_run_id):
    raise RuntimeError(
        f"LHP-MAN-002: manifest row for batch_id={batch_id} action={action_name} "
        f"already claimed by worker_run_id={readback[0]['worker_run_id']}"
    )
{% endif %}
extraction_type = "full" if hwm_value is None else "incremental"
wm.insert_new(
    run_id=run_id,
    source_system_id=source_system_id,
    schema_name=schema_name,
    table_name=table_name,
    watermark_column_name=watermark_column,
    watermark_value=str(hwm_value) if hwm_value is not None else None,
    row_count=0,
    extraction_type=extraction_type,
    previous_watermark_value=str(hwm_value) if hwm_value is not None else None,
    load_group=load_group,
)

extraction_succeeded = False
row_count = 0
new_hwm = None
run_landing_path = _run_landing_path(landing_root, run_id)


def _landing_has_parquet(path: str) -> bool:
    try:
        entries = dbutils.fs.ls(path)
    except Exception:
        return False
    return any(entry.path.endswith(".parquet") for entry in entries)

try:
    _log_phase("jdbc_read_start", extraction_type=extraction_type)
    df = (
        spark.read.format("jdbc")
        .option("url", {{ jdbc_url }})
        .option("user", {{ jdbc_user }})
        .option("password", {{ jdbc_password }})
        .option("driver", {{ jdbc_driver|tojson }})
        .option("dbtable", query)
        .option("queryTimeout", 3600)
        .load()
    )
    _log_phase("jdbc_read_complete", extraction_type=extraction_type)

    # HIPAA hook insertion point: between JDBC read and landing write.
    # Implementation deferred to HIPAA milestone — no executable code in this milestone.

    _log_phase("landing_write_start", landing_path=run_landing_path)
    df.write.mode("overwrite").format("parquet").save(run_landing_path)

    if _landing_has_parquet(run_landing_path):
        landed_df = spark.read.format("parquet").load(run_landing_path)
        agg_result = landed_df.agg(
            F.count("*").alias("row_count"),
            F.max(F.col(watermark_column)).alias("max_hwm"),
        ).first()
        row_count = agg_result["row_count"]
        new_hwm = agg_result["max_hwm"]
    else:
        # ADR-003 §Q3 / A2: a plain df.write.parquet of an empty DataFrame
        # emits only a _SUCCESS marker, no schema-bearing part file.
        # AutoLoader on the bronze side then fails the next run with
        # CF_EMPTY_DIR_FOR_SCHEMA_INFERENCE because cloudFiles.schemaLocation
        # is empty on the very first incremental run. Reuse the JDBC
        # df.schema (already known post-read) to write a 0-row, schema-bearing
        # parquet so the landing path is non-empty for AutoLoader.
        _log_phase(
            "landing_empty_schema_fallback",
            landing_path=run_landing_path,
            schema=df.schema.simpleString(),
        )
        spark.createDataFrame([], df.schema).coalesce(1).write.mode(
            "overwrite"
        ).format("parquet").save(run_landing_path)
        row_count = 0
        new_hwm = hwm_value
    _log_phase(
        "landing_write_complete",
        landing_path=run_landing_path,
        row_count=row_count,
        new_hwm=new_hwm,
    )

    extraction_succeeded = True
except Exception as e:
{% if execution_mode == "for_each" %}
    # Anomaly B (devtest 2026-04-26): mirror failure into b2_manifests so the
    # manifest is an authoritative state log on its own, not a join-only
    # surface coalesced against watermarks. Emitted BEFORE wm.mark_failed so
    # the R4 mark_failed→raise slice stays byte-identical with the legacy
    # branch (test_r4_raise_on_failure_block_verbatim_between_modes).
    # Best-effort: a failure here must not mask the real exception below.
    try:
        # SQL is intentionally inlined on one logical line so every rendered
        # line in this except-block stays indented (R4 helper invariant).
        spark.sql(
            f"UPDATE {manifest_table} SET execution_status = 'failed', updated_at = current_timestamp() "
            f"WHERE batch_id = {sql_literal(batch_id)} AND action_name = {sql_literal(action_name)}"
        )
    except Exception:  # noqa: BLE001 — manifest mirror is best-effort
        pass
{% endif %}
    # FR-L-02: audit the failure, then re-raise so Workflow task-level retries fire.
    wm.mark_failed(
        run_id=run_id,
        error_class=type(e).__name__,
        error_message=str(e)[:4096],
        load_group=load_group,
    )
    raise

# FR-L-01 / L2 §5.3: mark_complete OUTSIDE and AFTER the try/except so a
# failure inside mark_complete cannot re-enter the except branch and call
# mark_failed on an already-completed row. FR-L-06a is the DB-side guard;
# this structure is the first line of defence.
if extraction_succeeded:
    # Fall back to previous hwm when the batch observed no rows (agg returns
    # None on an empty result); propagating None would fail the numeric / string
    # validator inside mark_complete.
    completion_value = new_hwm if new_hwm is not None else hwm_value
    completion_value_sql = (
        str(completion_value) if completion_value is not None else ""
    )
    try:
        _log_phase(
            "finalization_prepare",
            landing_path=run_landing_path,
            row_count=row_count,
            watermark_value=completion_value_sql,
        )
        wm.mark_landed(
            run_id=run_id,
            watermark_value=completion_value_sql,
            row_count=row_count,
            load_group=load_group,
        )
        _log_phase(
            "finalization_commit_start",
            row_count=row_count,
            watermark_value=completion_value_sql,
        )
        wm.mark_complete(
            run_id=run_id,
            watermark_value=completion_value_sql,
            row_count=row_count,
            load_group=load_group,
        )
        _log_phase(
            "finalization_commit_complete",
            row_count=row_count,
            watermark_value=completion_value_sql,
        )
{% if execution_mode == "for_each" %}
        # Anomaly B (devtest 2026-04-26): transition manifest to 'completed'
        # so b2_manifests is a standalone source of truth instead of being
        # masked by validate.py's coalesce(worker_status, manifest_status).
        spark.sql(
            f"UPDATE {manifest_table} SET execution_status = 'completed', updated_at = current_timestamp() "
            f"WHERE batch_id = {sql_literal(batch_id)} AND action_name = {sql_literal(action_name)}"
        )
{% endif %}
    except TerminalStateGuardError:
        # Row was moved to terminal failure upstream; leave it, propagate.
        raise

    print(
        f"Extraction complete: {row_count} rows, "
        f"type={extraction_type}, hwm={completion_value}"
    )
