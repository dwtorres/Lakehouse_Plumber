# Databricks notebook source
# Extraction Job: {{ action_name }}
# Generated by Lakehouse Plumber — jdbc_watermark_v2
from datetime import datetime

from lhp.extensions.watermark_manager import WatermarkManager


# WatermarkManager for HWM tracking
wm = WatermarkManager(
    catalog="{{ wm_catalog }}",
    schema="{{ wm_schema }}",
)

# Get latest high-water mark
hwm_value = wm.get_latest_watermark(
    source_system_id="{{ source_system_id }}",
    schema_name="{{ schema_name }}",
    table_name="{{ table_name }}",
)

# Build JDBC query
jdbc_table = '{{ jdbc_table|replace("'", "\\'") }}'
{% if watermark_type == "timestamp" %}
if hwm_value is not None:
    hwm_safe = str(hwm_value).replace("'", "")
    query = (
        f"(SELECT * FROM {jdbc_table}"
        f" WHERE {{ watermark_column }} {{ watermark_operator }} '{hwm_safe}') AS t"
    )
else:
    query = f"(SELECT * FROM {jdbc_table}) AS t"
{% elif watermark_type == "numeric" %}
if hwm_value is not None:
    hwm_safe = (
        int(hwm_value)
        if float(hwm_value) == int(float(hwm_value))
        else float(hwm_value)
    )
    query = (
        f"(SELECT * FROM {jdbc_table}"
        f" WHERE {{ watermark_column }} {{ watermark_operator }} {hwm_safe}) AS t"
    )
else:
    query = f"(SELECT * FROM {jdbc_table}) AS t"
{% endif %}

# JDBC read
df = (
    spark.read.format("jdbc")
    .option("url", {{ jdbc_url }})
    .option("user", {{ jdbc_user }})
    .option("password", {{ jdbc_password }})
    .option("driver", "{{ jdbc_driver }}")
    .option("dbtable", query)
    .option("queryTimeout", 3600)
    .load()
)

# Cache for count + write
df.cache()
row_count = df.count()

if row_count > 0:
    # Repartition based on size
    if row_count < 1_000_000:
        df = df.repartition(1)
    else:
        df = df.repartition(4)

    # Write to landing zone as Parquet
    landing_path = "{{ landing_path }}"
    df.write.mode("append").format("parquet").save(landing_path)

    # Compute new watermark
    new_hwm = df.agg({"{{ watermark_column }}": "max"}).first()[0]
    if new_hwm is None:
        new_hwm = hwm_value

    # Record watermark
    pipeline_name = "{{ pipeline_name }}"
    run_id = f"{pipeline_name}_{{ action_name }}_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}"
    extraction_type = "full" if hwm_value is None else "incremental"

    wm.insert_new(
        source_system_id="{{ source_system_id }}",
        schema_name="{{ schema_name }}",
        table_name="{{ table_name }}",
        watermark_value=str(new_hwm),
        run_id=run_id,
        row_count=row_count,
        extraction_type=extraction_type,
    )

    print(
        f"Extraction complete: {row_count} rows, "
        f"type={extraction_type}, hwm={new_hwm}"
    )
else:
    print("No new rows to extract.")

df.unpersist()
