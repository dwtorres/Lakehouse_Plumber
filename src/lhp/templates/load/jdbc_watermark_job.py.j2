#
# Control flow matches the L2 §5.3 contract verbatim:
#   1. UTC session timezone (FR-L-07)
#   2. derive_run_id (FR-L-09) — job/task/attempt context, widget override, or local fallback
#   3. insert_new OUTSIDE the try block (FR-L-05) — a DuplicateRunError here means
#      no row was created, so mark_failed would have nothing to transition
#   4. try: JDBC read → aggregate → Parquet write (FR-L-02)
#   5. except: mark_failed(type(e).__name__, str(e)[:4096]) then raise
#   6. mark_complete OUTSIDE and AFTER the try/except (FR-L-01 / FR-L-06a)
from datetime import datetime, timezone
from decimal import Decimal

from pyspark.sql import functions as F

from lhp.extensions.watermark_manager import (
    TerminalStateGuardError,
    WatermarkManager,
)
from lhp.extensions.watermark_manager.runtime import derive_run_id
from lhp.extensions.watermark_manager.sql_safety import SQLInputValidator

# FR-L-07: DML against the watermark table must run in UTC.
spark.conf.set("spark.sql.session.timeZone", "UTC")

# FR-L-09: run_id provenance (Jobs context → widget override → local-<uuid> fallback).
run_id = derive_run_id(dbutils)

wm = WatermarkManager(
    spark,
    catalog={{ wm_catalog|tojson }},
    schema={{ wm_schema|tojson }},
)

# FR-L-03: every value that participates in SQL passes through SQLInputValidator.
# tojson emits a Python-safe literal so values containing quotes (e.g.
# '"Production"."Product"' for a Postgres pre-quoted identifier) round-trip
# unchanged into the notebook source.
source_system_id = SQLInputValidator.string({{ source_system_id|tojson }})
schema_name = SQLInputValidator.string({{ schema_name|tojson }})
table_name = SQLInputValidator.string({{ table_name|tojson }})
watermark_column = SQLInputValidator.string({{ watermark_column|tojson }})
jdbc_table = SQLInputValidator.string({{ jdbc_table|tojson }})

hwm_result = wm.get_latest_watermark(
    source_system_id=source_system_id,
    schema_name=schema_name,
    table_name=table_name,
)
hwm_value = hwm_result["watermark_value"] if hwm_result else None


def _ansi_quote_identifier(value: str) -> str:
    """Quote a JDBC identifier with ANSI double-quotes (portable remote-DB form).

    Spark's ``sql_identifier`` emitter uses backticks, which is wrong for
    Postgres/Oracle/SQL Server JDBC passthrough. This helper is intentionally
    local to the notebook and applies only after SQLInputValidator.string has
    rejected control characters and over-length input.
    """
    return '"' + value.replace('"', '""') + '"'


def _build_jdbc_query(hwm):
    """Compose the JDBC subquery string from validated Python values."""
    base = f"(SELECT * FROM {jdbc_table}) AS t"
    if hwm is None:
        return base
    {% if watermark_type == "timestamp" %}
    # Timestamp watermark: render as an ISO-8601 literal quoted for the remote DB.
    if isinstance(hwm, datetime):
        hwm_dt = hwm
    else:
        hwm_dt = datetime.fromisoformat(str(hwm))
    if hwm_dt.tzinfo is None:
        hwm_dt = hwm_dt.replace(tzinfo=timezone.utc)
    hwm_utc_iso = hwm_dt.astimezone(timezone.utc).isoformat(timespec="microseconds")
    hwm_literal = "'" + hwm_utc_iso.replace("'", "''") + "'"
    {% elif watermark_type == "numeric" %}
    # Numeric watermark: validator rejects float / NaN / Infinity before emission.
    if isinstance(hwm, Decimal):
        hwm_num = hwm
    else:
        try:
            hwm_num = int(str(hwm))
        except ValueError:
            hwm_num = Decimal(str(hwm))
    SQLInputValidator.numeric(hwm_num)
    hwm_literal = str(hwm_num)
    {% endif %}
    op = {{ watermark_operator|tojson }}
    if op not in (">=", ">", "<=", "<", "="):
        raise ValueError(f"unsupported watermark operator: {op!r}")
    col_quoted = _ansi_quote_identifier(watermark_column)
    return f"(SELECT * FROM {jdbc_table} /*lhp-where*/ {col_quoted} {op} {hwm_literal}) AS t".replace(
        "/*lhp-where*/", "WHERE"
    )


query = _build_jdbc_query(hwm_value)

# FR-L-05 / L2 §5.3: insert_new is OUTSIDE the try block. A DuplicateRunError
# here means no watermark row was created for this invocation, so mark_failed
# has nothing to transition and must not be called.
extraction_type = "full" if hwm_value is None else "incremental"
wm.insert_new(
    run_id=run_id,
    source_system_id=source_system_id,
    schema_name=schema_name,
    table_name=table_name,
    watermark_column_name=watermark_column,
    watermark_value=str(hwm_value) if hwm_value is not None else None,
    row_count=0,
    extraction_type=extraction_type,
    previous_watermark_value=str(hwm_value) if hwm_value is not None else None,
)

extraction_succeeded = False
row_count = 0
new_hwm = None

try:
    df = (
        spark.read.format("jdbc")
        .option("url", {{ jdbc_url }})
        .option("user", {{ jdbc_user }})
        .option("password", {{ jdbc_password }})
        .option("driver", {{ jdbc_driver|tojson }})
        .option("dbtable", query)
        .option("queryTimeout", 3600)
        .load()
    )

    agg_result = df.agg(
        F.count("*").alias("row_count"),
        F.max(F.col(watermark_column)).alias("max_hwm"),
    ).first()
    row_count = agg_result["row_count"]
    new_hwm = agg_result["max_hwm"]

    if row_count > 0:
        if row_count < 1_000_000:
            df = df.repartition(1)
        else:
            df = df.repartition(4)
        landing_path = {{ landing_path|tojson }}
        df.write.mode("append").format("parquet").save(landing_path)

    extraction_succeeded = True
except Exception as e:
    # FR-L-02: audit the failure, then re-raise so Workflow task-level retries fire.
    wm.mark_failed(
        run_id=run_id,
        error_class=type(e).__name__,
        error_message=str(e)[:4096],
    )
    raise

# FR-L-01 / L2 §5.3: mark_complete OUTSIDE and AFTER the try/except so a
# failure inside mark_complete cannot re-enter the except branch and call
# mark_failed on an already-completed row. FR-L-06a is the DB-side guard;
# this structure is the first line of defence.
if extraction_succeeded:
    # Fall back to previous hwm when the batch observed no rows (agg returns
    # None on an empty result); propagating None would fail the numeric / string
    # validator inside mark_complete.
    completion_value = new_hwm if new_hwm is not None else hwm_value
    completion_value_sql = (
        str(completion_value) if completion_value is not None else ""
    )
    try:
        wm.mark_complete(
            run_id=run_id,
            watermark_value=completion_value_sql,
            row_count=row_count,
        )
    except TerminalStateGuardError:
        # Row was moved to terminal failure upstream; leave it, propagate.
        raise

    print(
        f"Extraction complete: {row_count} rows, "
        f"type={extraction_type}, hwm={completion_value}"
    )
